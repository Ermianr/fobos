{
  "name": "fobos",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "effect": "^3.19.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "bun x ultracite check",
    "format": "bun x ultracite fix",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @fobos/db db:push",
    "db:studio": "turbo -F @fobos/db db:studio",
    "db:generate": "turbo -F @fobos/db db:generate",
    "db:migrate": "turbo -F @fobos/db db:migrate",
    "db:start": "turbo -F @fobos/db db:start",
    "db:watch": "turbo -F @fobos/db db:watch",
    "db:stop": "turbo -F @fobos/db db:stop",
    "db:down": "turbo -F @fobos/db db:down",
    "prepare": "husky"
  },
  "dependencies": {
    "@fobos/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@fobos/config": "workspace:*",
    "@google/genai": "^1.34.0",
    "@types/node": "catalog:",
    "husky": "latest",
    "lint-staged": "latest",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.0.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.5"
}
